# Copy to .env and adjust. Never commit .env with real secrets.
#   cp .env.example .env

# Environment: local | dev | staging | prod (prod disables /docs)
APP_ENV=local

APP_NAME=api-comerce-in

# Auth (JWT) - later chapters
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=30

# Admin: only this email may call admin routes (later)
ADMIN_EMAIL=you@example.com

# Database (Docker Compose publishes Postgres on host port 5433 → container 5432)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/ecommerce

# Stripe - later chapters
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
